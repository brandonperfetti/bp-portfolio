# Runtime mode
# local: fallback mode (hard-coded providers, empty local article states)
# notion: Notion CMS providers
CMS_PROVIDER=local

# Optional CMS revalidation webhook security
CMS_REVALIDATE_SECRET=replace-with-random-secret
# For Vercel cron auth (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=replace-with-random-secret

# SendGrid / contact
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Public site
NEXT_PUBLIC_SITE_URL=https://brandonperfetti.com

# Notion CMS (required for CMS_PROVIDER=notion)
NOTION_API_TOKEN=your_notion_integration_token
NOTION_API_VERSION=2025-09-03
NOTION_CMS_ARTICLES_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_AUTHORS_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_DEFAULT_AUTHOR_PAGE_ID=replace-with-author-page-id
NOTION_CMS_AUTOMATION_ERRORS_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_PAGES_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_PROJECTS_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_ROUTE_REGISTRY_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_SITE_SETTINGS_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_TECH_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_USES_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_WEBHOOK_EVENTS_DATA_SOURCE=collection://replace-with-id
NOTION_CMS_WORK_HISTORY_DATA_SOURCE=collection://replace-with-id
NOTION_CONTENT_DB_DATA_SOURCE=collection://replace-with-id
NOTION_IMAGE_JOBS_DATA_SOURCE=collection://replace-with-id
NOTION_ENABLE_ARTICLE_PROJECTION_SYNC=true
# Notion signs webhook payloads with the subscription verification token.
# Set either one (or both to the same value).
NOTION_WEBHOOK_VERIFICATION_TOKEN=replace-with-verification-token
NOTION_WEBHOOK_SECRET=

# OpenAI routes
OPENAI_API_KEY=replace-with-key
# Optional Hermes public-chat guardrails
# Set to true to disable each endpoint without code changes.
HERMES_DISABLE_CHAT=false
HERMES_DISABLE_IMAGE=false
# Per-IP fixed-window limits
HERMES_CHAT_RATE_LIMIT_PER_MINUTE=10
HERMES_IMAGE_RATE_LIMIT_PER_MINUTE=2
# Shared message/input limits
HERMES_MAX_MESSAGE_CHARS=1500
HERMES_MAX_MESSAGES=12
HERMES_MAX_COMPLETION_TOKENS=700
# Optional global daily image cap (0 disables daily cap)
HERMES_IMAGE_DAILY_LIMIT=0
# Optional in-memory guardrail bucket controls (until distributed store is adopted).
# Max total entries per rate/daily bucket map before oldest entries are evicted.
HERMES_GUARDRAILS_MAX_BUCKETS=5000
# Bucket TTL in milliseconds for stale-entry cleanup.
HERMES_GUARDRAILS_BUCKET_TTL_MS=86400000
# Optional bot challenge (enabled only when secret is set)
TURNSTILE_SECRET_KEY=

# Cloudinary (required for cover-regeneration worker)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Defaults to bp-portfolio/articles when omitted.
CLOUDINARY_CMS_COVERS_FOLDER=
# Max rows processed per cron run for cover regeneration.
CMS_COVER_REGEN_CRON_LIMIT=2
# Retention cleanup for Automation Errors database.
CMS_AUTOMATION_ERRORS_RETENTION_DAYS=30
CMS_AUTOMATION_ERRORS_RETENTION_LIMIT=100
# Failed webhook-event ledger cleanup retention.
CMS_WEBHOOK_EVENTS_RETENTION_DAYS=30
CMS_WEBHOOK_EVENTS_RETENTION_LIMIT=100
# Optional Image Jobs cleanup retention (non-winner completed rows only).
CMS_IMAGE_JOBS_RETENTION_DAYS=30
CMS_IMAGE_JOBS_CLEANUP_LIMIT=100
# Optional safety valve: when true, allows age-based fallback cleanup using last edited time
# if a row has no explicit Retention Until/Cleanup After date.
CMS_IMAGE_JOBS_CLEANUP_ALLOW_FALLBACK_AGE=false

# Content calendar idea seeding cron.
CALENDAR_SEEDING_ENABLED=true
CALENDAR_SEEDING_DRY_RUN=false
CALENDAR_SEEDING_MODEL=gpt-5-mini
CALENDAR_SEEDING_COUNT=5
CALENDAR_SEEDING_CADENCE_DAYS=7
CALENDAR_SEEDING_MAX_CONTEXT_ROWS=80
CALENDAR_SEEDING_PILLAR_LOOKBACK_ROWS=10
CALENDAR_SEEDING_MAX_PILLAR_SHARE_PERCENT=40

# SendGrid
SENDGRID_API_KEY=replace-with-key
# Set to "eu" only if using EU data residency.
SENDGRID_DATA_RESIDENCY=
# Legacy fallback key supported in code:
SENDGRID_LIST_ID=
SENDGRID_MAILING_ID=

# GitHub-powered tech curation cron.
GITHUB_TOKEN=
GITHUB_OWNER=
# Optional override for owner used by tech curation only.
GITHUB_TECH_OWNER=
# Optional comma-separated repo controls (owner/repo or repo-name).
GITHUB_TECH_REPOS_ALLOWLIST=
GITHUB_TECH_REPOS_DENYLIST=
GITHUB_TECH_REPO_LIMIT=60
GITHUB_TECH_MAX_REPO_AGE_MONTHS=24
GITHUB_TECH_MAX_PACKAGE_JSON_FILES_PER_REPO=20
GITHUB_TECH_INCLUDE_PRIVATE=false
TECH_CURATION_ENABLED=true
TECH_CURATION_DRY_RUN=false
TECH_CURATION_MIN_SCORE=4
TECH_CURATION_MAX_CANDIDATES=60
TECH_CURATION_AUTO_CREATE=true
TECH_CURATION_UPDATE_EXISTING=true
TECH_CURATION_DEFAULT_CREATE_STATUS=Review
TECH_CURATION_INCLUDE_UNMAPPED=false
TECH_CURATION_REQUIRE_AUTOMATION_MANAGED_FOR_UPDATES=true
TECH_CURATION_ENFORCE_INTEGRITY=true

# Optional Cloudinary folder for curated tech logos.
CLOUDINARY_CMS_TECH_LOGOS_FOLDER=bp-portfolio/tech
